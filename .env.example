# Application
APP_NAME="Mkaka Construction Management System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=mcms
DB_USER=mkaka_user
DB_PASSWORD=mkaka_secure_pass_2026
DB_ROOT_PASSWORD=mkaka_root_2026

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=mkaka_redis_pass_2026

# OnlyOffice
ONLYOFFICE_URL=http://localhost:8080
ONLYOFFICE_JWT_SECRET=mkaka_onlyoffice_secret_2026_change_in_production
ONLYOFFICE_JWT_HEADER=Authorization

# Mail (Development - MailHog)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@mkakaconstruction.com
MAIL_FROM_NAME="Mkaka Construction"

# Mail (Production - Real SMTP)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your-email@gmail.com
# MAIL_PASS=your-app-password
# MAIL_ENCRYPTION=tls

# Security
APP_KEY=base64:your_32_character_app_key_generate_with_openssl
JWT_SECRET=your_jwt_secret_key_here

# File Upload
MAX_UPLOAD_SIZE=20971520
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# GPS Validation
GPS_VALIDATION_ENABLED=true
MALAWI_MIN_LAT=-17.125
MALAWI_MAX_LAT=-9.367
MALAWI_MIN_LNG=32.674
MALAWI_MAX_LNG=35.924

# PWA
PWA_NAME="Mkaka Construction"
PWA_SHORT_NAME="Mkaka"
PWA_THEME_COLOR=#FF8A00
PWA_BACKGROUND_COLOR=#ffffff
