# ============================================
# Mkaka Construction - Git Ignore
# ============================================

# Environment files
.env
.env.local
.env.*
!.env.example

# Dependencies
/vendor/
node_modules/
# Build tools (shouldn't be in PHP project!)
.gradle/
gradle/
build/
*.gradle
gradlew
gradlew.bat

# Make sure these are definitely ignored
vendor/
node_modules/
mcms/vendor/
mcms/node_modules/

# Logs
/logs/*.log
/logs/*/*.log
*.log

# Uploads
/public/uploads/*
!/public/uploads/.htaccess

# Storage
/storage/temp/*
/storage/backups/*
/storage/cache/*
!/storage/.gitkeep

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# Composer
composer.phar

# Test coverage
/coverage/

# ============================================
# DOCKER - VERY IMPORTANT!
# ============================================
# Docker volumes (these create thousands of files!)
mysql_data/
onlyoffice_data/
onlyoffice_logs/
onlyoffice_fonts/
redis_data/
nginx_logs/

# Docker runtime files
*.pid
*.sock

# Application runtime (generated by Laravel/PHP)
mcms/storage/logs/*
mcms/storage/framework/cache/*
mcms/storage/framework/sessions/*
mcms/storage/framework/views/*
mcms/bootstrap/cache/*
mcms/public/uploads/*
!mcms/public/uploads/.gitkeep

# Temporary files
tmp/
temp/
*.tmp
*.cache